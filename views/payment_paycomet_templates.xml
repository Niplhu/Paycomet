<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        redirect_form: used by _get_specific_rendering_values to carry the
        Paycomet challenge URL to the frontend.  Odoo serialises this template
        into processingValues.redirect_form_html; our JS reads the form's
        action attribute and opens it in an iframe overlay instead of
        performing a full-page redirect.
    -->
    <template id="redirect_form">
        <form t-att-action="form_url" method="get" id="o_payment_redirect_form"/>
    </template>

    <!--
        inline_form: shown next to the payment option while the user is on the
        checkout page (before clicking Pay).  Communicates that the secure
        Paycomet form will appear in a pop-up overlay on the same page.
    -->
    <template id="inline_form">
        <div class="o_jetframe_inline_info alert alert-info d-flex align-items-center gap-2 mb-0 py-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                 class="flex-shrink-0">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <span>Al pulsar <strong>Pagar</strong> se abrirá el formulario seguro de Paycomet en esta misma página.</span>
        </div>
    </template>

</odoo>
